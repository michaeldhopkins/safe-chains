/target
/fuzz/target
/fuzz/artifacts
# `cargo fuzz coverage` output: multi-MB .profraw/.profdata build artifacts.
/fuzz/coverage
# Keep a hand-curated committed seed corpus (seed-*); ignore libFuzzer's hash-named generated
# entries AND the registry-derived seeds from gen-fuzz-corpus (gen-*).
/fuzz/corpus/parse/*
!/fuzz/corpus/parse/seed-*
# Registry-derived fuzz dictionary (regenerated by gen-fuzz-corpus, never committed).
/fuzz/dict
.claude
